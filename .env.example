EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Full URL of the Vercel deployment (no trailing slash).
# Supabase uses this as the redirect target in confirmation emails.
# In Vercel: Settings > Environment Variables > EXPO_PUBLIC_APP_URL
# Also set "Site URL" in Supabase Dashboard > Auth > URL Configuration to this same value.
EXPO_PUBLIC_APP_URL=https://your-app.vercel.app
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STRIPE_SECRET_KEY=sk_test_your_key

# ── SendGrid (FASE 1) ─────────────────────────────────────────────────────────
# Set via `supabase secrets set SENDGRID_API_KEY=...` for edge functions
# Set in Vercel: Settings > Environment Variables > SENDGRID_API_KEY
# Set in EAS: eas secret:create --scope project --name SENDGRID_API_KEY --value ...
SENDGRID_API_KEY=SG.your_key_here
FROM_EMAIL=noreply@yourapp.com
